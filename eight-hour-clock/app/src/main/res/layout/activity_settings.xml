<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 顶部霓虹渐变条 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@drawable/neon_bar" />

    <!-- 发光标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:letterSpacing="0.05"
        android:shadowColor="@color/accent"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="16"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:letterSpacing="0.35"
        android:text="@string/header_sub"
        android:textColor="@color/accent2"
        android:textSize="11sp" />

    <!-- 参数卡片：霓虹描边 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/card_bg"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.15"
            android:text="@string/base_hours_label"
            android:textColor="@color/accent"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/edit_hours"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/field_bg"
            android:inputType="number"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:letterSpacing="0.15"
            android:text="@string/count_label"
            android:textColor="@color/accent"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/edit_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/field_bg"
            android:inputType="number"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:letterSpacing="0.15"
            android:text="@string/interval_label"
            android:textColor="@color/accent"
            android:textSize="11sp" />

        <EditText
            android:id="@+id/edit_interval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/field_bg"
            android:inputType="number"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="@drawable/btn_primary"
        android:text="@string/save_button"
        android:textColor="#020508"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_open_clock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/btn_secondary"
        android:text="@string/open_clock_button"
        android:textColor="@color/accent" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:letterSpacing="0.2"
        android:text="@string/footer_text"
        android:textColor="@color/text_secondary"
        android:textSize="10sp" />

</LinearLayout>
